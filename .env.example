# ============================================
# HireLoop AI - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================

# ── General ──────────────────────────────────
NODE_ENV=development
PORT=4000

# ── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql://hireloop:hireloop_secret@localhost:5432/hireloop_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hireloop_db
DB_USER=hireloop
DB_PASSWORD=hireloop_secret

# ── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ─────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── AI Engine (FastAPI) ──────────────────────
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=your-ai-engine-api-key

# ── Email (Development - NodeMailer) ─────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-pass
EMAIL_FROM=noreply@hireloop.ai

# ── Email (Production - AWS SES) ─────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# SES_FROM_EMAIL=noreply@hireloop.ai

# ── Gemini ───────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── HuggingFace ──────────────────────────────
HUGGINGFACE_API_KEY=your-huggingface-api-key

# ── File Upload ──────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
