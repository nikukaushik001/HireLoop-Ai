# ============================================
# HireLoop API — Environment Variables
# ============================================

# ── Server ───────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://hireloop:hireloop_secret@localhost:5432/hireloop_db

# ── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=change-this-to-a-random-string-min-32-chars
JWT_REFRESH_SECRET=change-this-to-another-random-string-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ─────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── AI Engine ────────────────────────────────
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=change-this-to-a-secret-api-key

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
