PORT=4000
# Supabase transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.your_db:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase session pooler for Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.your_db:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

JWT_SECRET="your_super_secret_jwt_key_here"
CORS_ORIGIN="http://localhost:5173"
AI_SERVICE_URL="http://127.0.0.1:8000"
