// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── 1. Users ────────────────────────────────────────────────────────
// Recruiters and admins who log in to the system.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(RECRUITER)
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Password Reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // Relationships
  jobs         Job[]
  candidates   Candidate[]
}

enum Role {
  SUPERADMIN
  ADMIN
  RECRUITER
}

// ── 2. Jobs ─────────────────────────────────────────────────────────
// Job openings created by recruiters.
model Job {
  id           String   @id @default(uuid())
  title        String
  description  String
  requirements String?  // Optional detailed requirements
  department   String?
  status       JobStatus @default(OPEN)
  
  // Embedding for future AI job matching
  embedding    Float[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  createdBy    String
  user         User     @relation(fields: [createdBy], references: [id])
  applications Application[]
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

// ── 3. Resumes ──────────────────────────────────────────────────────
// Uploaded PDFs and their raw extracted data.
model Resume {
  id            String   @id @default(uuid())
  fileName      String
  filePath      String
  rawText       String?  // Text extracted by PyMuPDF
  parsedData    Json?    // Structured JSON from Gemini
  parseStatus   ParseStatus @default(PROCESSING)
  errorMessage  String?  // If parsing fails

  // Versioning and isolated embedding
  version       Int      @default(1)
  embedding     Float[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  candidateId   String?  // Nullable initially until parsing links it to a candidate
  candidate     Candidate? @relation(fields: [candidateId], references: [id])
  applications  Application[]
}

enum ParseStatus {
  PROCESSING
  COMPLETED
  NEEDS_REVIEW
  FAILED
}

// ── 4. Candidates ───────────────────────────────────────────────────
// The permanent Talent Pool. Parsed candidate profiles.
model Candidate {
  id              String   @id @default(uuid())
  email           String
  name            String
  phone           String?
  skills          String[] // Array of skills parsed by AI
  experienceYears Int?
  currentCompany  String?
  location        String?
  cultureFitSummary String?
  
  // Embedding for fast similarity search during matching
  embedding       Float[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  resumes         Resume[]
  applications    Application[]

  @@unique([email, userId])
}


// ── 5. Applications ─────────────────────────────────────────────────
// Connects a Candidate to a specific Job opening.
model Application {
  id            String   @id @default(uuid())
  
  aiScore       Int?     // 0-100 relevance score from Gemini
  aiReasoning   String?  // Explanation of the score
  status        AppStatus @default(NEW)
  source        AppSource @default(MANUAL) // Did they apply manually or were they AI recommended?

  appliedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  candidateId   String
  jobId         String
  resumeId      String?
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume        Resume?   @relation(fields: [resumeId], references: [id])
  interviews    Interview[]

  @@unique([candidateId, jobId]) // A candidate can only apply once per job
}

enum AppStatus {
  NEW
  SHORTLISTED
  INTERVIEWING
  OFFERED
  REJECTED
}

enum AppSource {
  MANUAL
  AI_RECOMMENDED
}

// ── 6. Interviews ───────────────────────────────────────────────────
// Scheduled interviews and the feedback provided by the interviewer.
model Interview {
  id              String   @id @default(uuid())
  scheduledAt     DateTime
  durationMinutes Int      @default(60)
  meetingLink     String?
  interviewerName String

  status          InterviewStatus @default(SCHEDULED)

  // Feedback (Merged into this table for simplicity)
  rating          Int?     // 1-5 rating
  feedbackText    String?
  recommendation  HireRecommendation?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum HireRecommendation {
  STRONG_HIRE
  HIRE
  NO_HIRE
}
